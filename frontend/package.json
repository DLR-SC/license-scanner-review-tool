{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate": "openapi-generator-cli generate -i openapi.json -g typescript-fetch -o src/client --additional-properties=supportsES6=true,withSeparateModelsAndApi=true,modelPackage=models,apiPackage=apis",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "type-check": "vue-tsc --build",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check --experimental-cli src/"
  },
  "dependencies": {
    "@iconify-json/carbon": "^1.2.20",
    "cytoscape": "^3.33.2",
    "cytoscape-dagre": "^2.5.0",
    "diff": "^8.0.4",
    "minimatch": "^10.2.4",
    "pinia": "^3.0.4",
    "spdx-expression-parse": "^4.0.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.31.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/cytoscape-dagre": "^2.3.4",
    "@types/node": "^24.11.0",
    "@types/spdx-expression-parse": "^4.0.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-playwright": "^2.8.0",
    "eslint-plugin-vue": "~10.8.0",
    "oxlint": "~1.50.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@11.0.6+sha512.97f906e1da2bedac3df83cadae04b4753a130092dd49d55cd36825ad3e623e9df3f97754f8f259e699172a360fac569acf2f908e7732bdae3eddb2dcf7e121fd"
}
